{
  "workspace": [
    "./workers/shared/"
  ],
  "imports": {
    "@cloudflare/workers-types": "npm:@cloudflare/workers-types@^4.20260214.0",
    "@hono/hono": "jsr:@hono/hono@^4.11.9",
    "@std/assert": "jsr:@std/assert@1",
    "@std/testing": "jsr:@std/testing@1",
    "@zod/zod": "jsr:@zod/zod@^4.3.6",
    "@std/": "jsr:@std/",
    "drizzle-kit": "npm:drizzle-kit@^0.31.9",
    "drizzle-orm": "npm:drizzle-orm@^0.45.1",
    "drizzle-orm/sqlite-core": "npm:drizzle-orm@^0.45.1/sqlite-core",
    "neverthrow": "npm:neverthrow@^8.1.1"
  },
  "tasks": {
    "dev:api": "wrangler dev --config workers/api/wrangler.jsonc",
    "dev:processor": "wrangler dev --config workers/processor/wrangler.jsonc",
    "db:generate": "deno run -A npm:drizzle-kit generate",
    "db:migrate": "deno run -A npm:drizzle-kit migrate",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check workers/**/*.ts drizzle.config.ts && deno lint && deno fmt --check",
    "pre-commit": "deno task check && deno test"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "noImplicitReturns": true
  },
  "fmt": {
    "lineWidth": 120,
    "exclude": [
      "dist/",
      ".agent/",
      ".wrangler/",
      "node_modules/",
      "pnpm-lock.yaml"
    ]
  },
  "lint": {
    "exclude": [
      "dist/",
      ".agent/",
      ".wrangler/",
      "node_modules/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "eqeqeq",
        "default-param-last",
        "guard-for-in",
        "explicit-function-return-type",
        "explicit-module-boundary-types",
        "no-explicit-any",
        "no-throw-literal",
        "no-await-in-loop",
        "no-async-promise-executor"
      ]
    }
  },
  "nodeModulesDir": "auto"
}
