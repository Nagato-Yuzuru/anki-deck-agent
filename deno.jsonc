{
  "workspace": [
    "./workers"
  ],
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.11.9",
    "@std/assert": "jsr:@std/assert@1",
    "@zod/zod": "jsr:@zod/zod@^4.3.6",
    "@std/": "jsr:@std/"
  },
  "tasks": {
    "dev:api": "denoflare serve workers/api/index.ts",
    "dev:processor": "denoflare serve workers/processor/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check **/*.ts && deno lint && deno fmt --check",
    "pre-commit": "deno task check && deno test"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "noImplicitReturns": true
  },
  "fmt": {
    "lineWidth": 120,
    "exclude": [
      "dist/",
      ".denoflare/"
    ]
  },
  "lint": {
    "exclude": [
      "dist/",
      ".denoflare/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "eqeqeq",
        "default-param-last",
        "guard-for-in",
        "explicit-function-return-type",
        "explicit-module-boundary-types",
        "no-explicit-any",
        "no-throw-literal",
        "no-await-in-loop",
        "no-async-promise-executor"
      ]
    }
  }
}